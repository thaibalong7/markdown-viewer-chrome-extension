{
  "name": "markdown-plus",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Chrome extension: Markdown Plus viewer (MV3)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "analyze": "ANALYZE=1 vite build",
    "size:report": "du -sh dist && du -ch dist/assets/*.js | tail -1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@vitejs/plugin-react": "^6.0.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "sass": "^1.99.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@mdit/plugin-katex": "^0.25.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@tanstack/react-virtual": "^3.13.23",
    "dompurify": "^3.3.3",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "mermaid": "^11.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2"
  }
}
