{
  "manifest_version": 3,
  "name": "Markdown Plus",
  "version": "0.1.0",
  "description": "Auto-detect and render Markdown files in a readable viewer UI.",
  "permissions": ["storage", "offscreen", "downloads"],
  "host_permissions": ["<all_urls>", "file:///*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Markdown Plus",
    "default_popup": "src/popup/index.html"
  },
  "options_page": "src/options/index.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "src/popup/icon-placeholder-16.png",
    "48": "src/popup/icon-placeholder-48.png",
    "128": "src/popup/icon-placeholder-128.png"
  }
}